{
   "permissions": {
    "allow": [
      "Bash(wc *)",
      "Bash(python *)",
      "Write(outputs/graph_data/*)",
      "Write(outputs/queries/*)",
      "Bash(python3 *)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "graph-skill-designer\\(.*\\)|graph-schema-designer\\(.*\\)|graph-extractor\\(.*\\)|graph-importer\\(.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log_agent_output.sh | tee -a logs/agents_$(date +%Y%m%d).log",
            "statusMessage": "Logging agent start..."
          }
        ]
      },
      {
        "matcher": "graph-skill-designer\\(.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/designdoc_backup.sh | tee -a logs/agents_$(date +%Y%m%d).log",
            "statusMessage": "Creating design-doc backup..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "graph-skill-designer\\(.*\\)|graph-schema-designer\\(.*\\)|graph-extractor\\(.*\\)|graph-importer\\(.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log_agent_output.sh | tee -a logs/agents_$(date +%Y%m%d).log",
            "statusMessage": "Logging agent completion..."
          }
        ]
      }
    ]
  }
}
